{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "!!**/convex/_generated",
      "!!.context/*",
      "!!**/convex/components",
      "!!**/src/routeTree.gen.ts",
      "!!**/src/styles.css",
      "!!**/src/components/ui/*",
      "!!**/src/data/*",
      "!!src/routes/-auth-redirect.ts",
      "!!src/components/storybook/*",
      "!!e2e/*",
      "!!src/test/*",
      "!!convex/ledger/__tests__/*",
      "!!specs/**/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    },
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNestedTernary": "warn",
        "useFilenamingConvention": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "./_generated/server": {
                "importNames": ["query", "mutation", "action"],
                "message": "Use fluent chains from './fluent' (e.g. authedQuery, ledgerMutation). See CLAUDE.md."
              },
              "../_generated/server": {
                "importNames": ["query", "mutation", "action"],
                "message": "Use fluent chains from '../fluent' (e.g. authedQuery, ledgerMutation). See CLAUDE.md."
              }
            }
          }
        }
      },
      "suspicious": {
        "noTsIgnore": "off",
        "noConsole": "off",
        "useAwait": "off",
        "noUnknownAtRules": "off",
        "noBitwiseOperators": "off",
        "noAlert": "warn",
        "noEmptyBlockStatements": "warn"
      },
      "complexity": {
        "noVoid": "off",
        "noExcessiveCognitiveComplexity": "warn"
      },
      "a11y": {
        "useSemanticElements": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
