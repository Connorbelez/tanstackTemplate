#!/usr/bin/env sh
set -e

# Use NUL-separated paths so filenames with spaces or `$` (e.g. TanStack `$param`
# routes) are not word-split or expanded by the shell.
if git diff --cached --quiet; then
	exit 0
fi

git diff --cached --name-only --diff-filter=ACMR -z | xargs -0 bunx ultracite fix
git update-index --again
